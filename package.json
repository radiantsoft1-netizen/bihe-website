{
  "name": "bihe-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:clean": "node scripts/dev-clean.mjs",
    "dev:fast": "next dev --turbopack --hostname 127.0.0.1 --port 3000",
    "dev:status": "node scripts/dev-status.mjs",
    "clean": "rm -rf .next .next-build node_modules/.cache",
    "verify": "node scripts/verify.mjs",
    "build": "BIHE_DIST_DIR=.next-build next build",
    "start": "BIHE_DIST_DIR=.next-build next start --hostname 127.0.0.1 --port 3000",
    "lint": "next lint",
    "download-assets": "node scripts/download-assets.mjs"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "lenis": "^1.3.23",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "typescript": "^5.8.3"
  }
}
