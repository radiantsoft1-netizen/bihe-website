# dependencies
node_modules/

# next.js (public site)
.next/
.next-build/
out/
tsconfig.tsbuildinfo

# environment (never commit secrets)
.env
.env.*
!.env.example
bihe-admin/.env
bihe-admin/.env.*

# gallery uploads (local dev)
data/gallery.json
public/uploads/gallery/*
!public/uploads/gallery/.gitkeep

# Laravel admin (bihe-admin) — vendor is installed in CI and on server
bihe-admin/vendor/
bihe-admin/.phpunit.cache/
bihe-admin/.phpunit.result.cache
bihe-admin/.ftp-deploy-sync-state.json
bihe-admin/public/hot
bihe-admin/public/storage
bihe-admin/storage/*.key
bihe-admin/storage/logs/*
!bihe-admin/storage/logs/.gitignore
bihe-admin/storage/framework/cache/data/*
!bihe-admin/storage/framework/cache/.gitignore
bihe-admin/storage/framework/sessions/*
!bihe-admin/storage/framework/sessions/.gitignore
bihe-admin/storage/framework/views/*
!bihe-admin/storage/framework/views/.gitignore
bihe-admin/bootstrap/cache/*
!bihe-admin/bootstrap/cache/.gitignore
bihe-admin/node_modules/
bihe-admin/.phpactor.json
bihe-admin/Homestead.json
bihe-admin/Homestead.yaml
bihe-admin/auth.json

# IDE / OS
.DS_Store
*.pem
.idea/
.vscode/
.fleet/

# debug
npm-debug.log*
yarn-error.log*
.cursor/debug-*.log

# Local scratch / export artifacts
tmp/

# Local Laravel SQLite (production uses MySQL on Hostinger)
bihe-admin/database/*.sqlite
bihe-admin/database/*.sqlite-journal

# keep composer.lock committed (do not ignore bihe-admin/composer.lock)
.vercel
