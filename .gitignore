# dependencies
node_modules/
Frontend/node_modules/

# next.js (public site)
Frontend/.next/
Frontend/.next-build/
Frontend/out/
Frontend/tsconfig.tsbuildinfo

# environment (never commit secrets)
.env
.env.*
!.env.example
Frontend/.env
Frontend/.env.*
!Frontend/.env.example
Backend/.env
Backend/.env.*

# gallery uploads (local dev)
data/gallery.json
Frontend/public/uploads/gallery/*
!Frontend/public/uploads/gallery/.gitkeep

# Laravel admin (Backend) — vendor is installed in CI and on server
Backend/vendor/
Backend/.phpunit.cache/
Backend/.phpunit.result.cache
Backend/.ftp-deploy-sync-state.json
Backend/public/hot
Backend/public/storage
Backend/storage/*.key
Backend/storage/logs/*
!Backend/storage/logs/.gitignore
Backend/storage/framework/cache/data/*
!Backend/storage/framework/cache/.gitignore
Backend/storage/framework/sessions/*
!Backend/storage/framework/sessions/.gitignore
Backend/storage/framework/views/*
!Backend/storage/framework/views/.gitignore
Backend/bootstrap/cache/*
!Backend/bootstrap/cache/.gitignore
Backend/node_modules/
Backend/.phpactor.json
Backend/Homestead.json
Backend/Homestead.yaml
Backend/auth.json

# IDE / OS
.DS_Store
*.pem
.idea/
.vscode/
.fleet/

# debug
npm-debug.log*
yarn-error.log*
.cursor/debug-*.log

# Local scratch / export artifacts
tmp/

# Local Laravel SQLite (production uses MySQL on Hostinger)
Backend/database/*.sqlite
Backend/database/*.sqlite-journal

# keep composer.lock committed (do not ignore Backend/composer.lock)
.vercel
