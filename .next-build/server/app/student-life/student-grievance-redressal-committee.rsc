16:["$","p","The committee serves as an important platform fo",{"className":"grc-page__text","children":"The committee serves as an important platform for stakeholders to express their concerns and seek timely resolution of issues related to academics, administration, infrastructure, facilities, examinations, student services, workplace environment, and general welfare. It is committed to safeguarding the rights and interests of all members of the institution while fostering mutual respect, inclusiveness, and harmony."}]
17:["$","section",null,{"className":"grc-page__objectives","aria-labelledby":"grc-objectives-title","children":["$","div",null,{"className":"grc-page__container","children":[["$","$L15",null,{"children":["$","div",null,{"className":"section-header","children":[["$","span",null,{"className":"section-badge","children":[["$","span",null,{"className":"section-badge__dot","aria-hidden":true}],"SGRC"]}],["$","h2",null,{"id":"grc-objectives-title","className":"section-title section-title--center","children":"Primary Objectives"}]]}]}],["$","ul",null,{"className":"grc-page__objective-grid","children":[["$","li","To provide a structured and accessible mechanism for grievance redressal.",{"children":["$","$L15",null,{"delay":40,"children":["$","article",null,{"className":"grc-page__objective-card","children":[["$","span",null,{"className":"grc-page__objective-index","aria-hidden":true,"children":"01"}],["$","p",null,{"className":"grc-page__objective-text","children":"To provide a structured and accessible mechanism for grievance redressal."}]]}]}]}],["$","li","To ensure fair, impartial, and confidential handling of complaints.",{"children":["$","$L15",null,{"delay":80,"children":["$","article",null,{"className":"grc-page__objective-card","children":[["$","span",null,{"className":"grc-page__objective-index","aria-hidden":true,"children":"02"}],["$","p",null,{"className":"grc-page__objective-text","children":"To ensure fair, impartial, and confidential handling of complaints."}]]}]}]}],["$","li","To promote a supportive and student-friendly academic environment.",{"children":["$","$L15",null,{"delay":120,"children":["$","article",null,{"className":"grc-page__objective-card","children":[["$","span",null,{"className":"grc-page__objective-index","aria-hidden":true,"children":"03"}],["$","p",null,{"className":"grc-page__objective-text","children":"To promote a supportive and student-friendly academic environment."}]]}]}]}],["$","li","To address issues affecting the welfare and well-being of students and employees.",{"children":["$","$L15",null,{"delay":160,"children":["$","article",null,{"className":"grc-page__objective-card","children":[["$","span",null,{"className":"grc-page__objective-index","aria-hidden":true,"children":"04"}],["$","p",null,{"className":"grc-page__objective-text","children":"To address issues affecting the welfare and well-being of students and employees."}]]}]}]}],["$","li","To uphold the principles of natural justice, transparency, and accountability.",{"children":["$","$L15",null,{"delay":200,"children":["$","article",null,{"className":"grc-page__objective-card","children":[["$","span",null,{"className":"grc-page__objective-index","aria-hidden":true,"children":"05"}],["$","p",null,{"className":"grc-page__objective-text","children":"To uphold the principles of natural justice, transparency, and accountability."}]]}]}]}],["$","li","To encourage constructive dialogue and amicable resolution of disputes.",{"children":["$","$L15",null,{"delay":240,"children":["$","article",null,{"className":"grc-page__objective-card","children":[["$","span",null,{"className":"grc-page__objective-index","aria-hidden":true,"children":"06"}],["$","p",null,{"className":"grc-page__objective-text","children":"To encourage constructive dialogue and amicable resolution of disputes."}]]}]}]}]]}]]}]}]
18:["$","section",null,{"className":"grc-page__process","aria-labelledby":"grc-process-title","children":["$","div",null,{"className":"grc-page__container","children":["$","$L15",null,{"children":["$","div",null,{"className":"grc-page__process-panel","children":[["$","h2",null,{"className":"grc-page__panel-title","id":"grc-process-title","children":"Grievance Handling Process"}],["$","p",null,{"className":"grc-page__text","children":"The committee receives grievances through formal applications, written complaints, online submissions, or direct representations from stakeholders. Upon receipt of a grievance, the committee examines the matter carefully, gathers relevant information, and undertakes necessary investigations while maintaining confidentiality and impartiality. Appropriate recommendations and corrective measures are then implemented to ensure effective resolution."}]]}]}]}]}]
