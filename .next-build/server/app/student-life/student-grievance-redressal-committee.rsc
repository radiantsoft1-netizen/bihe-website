1a:["$","section",null,{"className":"grc-page__commitment","aria-label":"Institutional commitment","children":["$","div",null,{"className":"grc-page__container","children":["$","$L15",null,{"children":["$","div",null,{"className":"grc-page__commitment-panel","children":[["$","p","The Grievance Redressal and Welfare Committee al",{"className":"grc-page__text","children":"The Grievance Redressal and Welfare Committee also plays a proactive role in creating awareness about institutional policies, rights, responsibilities, and available support systems. Regular interactions, counselling sessions, and feedback mechanisms are encouraged to identify concerns at an early stage and prevent the escalation of issues."}],["$","p","The committee functions in coordination with var",{"className":"grc-page__text","children":"The committee functions in coordination with various statutory and non-statutory bodies of the institution, ensuring that grievances are addressed efficiently and in accordance with institutional regulations and applicable guidelines. Periodic reviews are conducted to evaluate the effectiveness of grievance redressal mechanisms and to recommend improvements wherever necessary."}],["$","p","Through its commitment to fairness, transparency",{"className":"grc-page__text","children":"Through its commitment to fairness, transparency, and responsiveness, the Grievance Redressal and Welfare Committee contributes significantly to maintaining a positive institutional culture, strengthening stakeholder confidence, and promoting the overall welfare and development of the BIHE community."}]]}]}]}]}]
