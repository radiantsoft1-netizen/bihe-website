# Laravel Backend — public site fetches API from this URL (no trailing slash)
# Local: http://127.0.0.1:8099
# Production: https://admin.bihedvg.org
ADMIN_ORIGIN=http://127.0.0.1:8099

# Same host as ADMIN_ORIGIN — used by the public site to fetch news, faculty, etc.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8099

# Public website URL (production: https://bihedvg.org) — optional; used in metadata
# NEXT_PUBLIC_SITE_URL=https://bihedvg.org

# Shared secret for Laravel → Next.js cache refresh after admin saves
# Must match REVALIDATE_SECRET in Backend/.env
REVALIDATE_SECRET=bihe-local-revalidate
