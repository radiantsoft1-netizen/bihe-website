{
  "name": "bihe-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:clean": "node scripts/dev-clean.mjs",
    "dev:fast": "next dev --turbopack --hostname 127.0.0.1 --port 3000",
    "dev:status": "node scripts/dev-status.mjs",
    "clean": "rm -rf .next .next-build node_modules/.cache",
    "verify": "node scripts/verify.mjs",
    "verify:backend": "bash scripts/verify-backend.sh",
    "api:check": "node scripts/check-api-link.mjs",
    "build": "next build",
    "build:local": "BIHE_DIST_DIR=.next-build next build",
    "build:hostinger": "next build",
    "start": "next start --hostname 0.0.0.0 --port ${PORT:-3000}",
    "start:local": "BIHE_DIST_DIR=.next-build next start --hostname 127.0.0.1 --port 3000",
    "start:hostinger": "next start --hostname 0.0.0.0 --port ${PORT:-3000}",
    "lint": "next lint",
    "download-assets": "node scripts/download-assets.mjs",
